# Salin file ini jadi .env dan isi nilainya
# Railway: set variabel ini di Settings → Variables

# Path database SQLite (cache fundamental PE/PBV/ROE, dst).
# Railway: set ke /data/fundamental_cache.db dan mount Volume ke /data
# agar cache tidak hilang setiap redeploy.
DATABASE_URL=fundamental_cache.db

# Redis untuk cache TTL (analisis & harga real-time) dan rate limit per-IP.
# Tanpa ini aplikasi tetap jalan (fail-open ke "tanpa cache/rate-limit"),
# jadi hanya wajib diisi kalau menjalankan >1 instance/worker.
REDIS_URL=redis://localhost:6379/0
