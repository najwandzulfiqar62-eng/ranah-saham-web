# Salin file ini jadi .env dan isi nilainya
# Railway: set variabel ini di Settings → Variables

# Path database SQLite (cache fundamental, riwayat sinyal, forum, dst).
# SENGAJA DIKOSONGKAN di sini -- default kode (ranah_saham.db) adalah file
# produksi yang sudah berisi data sungguhan. Isi baris ini HANYA kalau
# benar2 sengaja pindah ke file DB lain (mis. Railway: /data/ranah_saham.db
# dgn Volume di-mount ke /data supaya data tidak hilang tiap redeploy).
DATABASE_URL=

# Redis untuk cache TTL (analisis & harga real-time) dan rate limit per-IP.
# Tanpa ini aplikasi tetap jalan (fail-open ke "tanpa cache/rate-limit"),
# jadi hanya wajib diisi kalau menjalankan >1 instance/worker.
REDIS_URL=redis://localhost:6379/0

# Interval (detik) siklus auto-audit sinyal berjalan di background selama
# aplikasi hidup (refresh Top Pick + audit sinyal OPEN). Default 600 = 10
# menit.
SIGNAL_AUTO_INTERVAL_SECONDS=600

# Kode rahasia admin Forum (badge "Admin" + hak hapus thread/balasan).
# Kosong = fitur admin forum nonaktif sepenuhnya (fail-closed), forum tetap
# jalan normal tanpa admin. Pilih string acak yang panjang -- proteksi
# brute-force di sini mengandalkan rate limit, bukan kerumitan kode.
FORUM_ADMIN_SECRET=

# WebSocket ShadowStream (upstream) utk panel Order Book Live: app konek ke
# sini, ambil order book, relay ke /ws/ihsg. ShadowStream broadcast lewat
# WS-nya sendiri (bukan Redis). Contoh: wss://<sub>.ngrok-free.app/ws/ihsg
# atau ws://localhost:PORT/ws/ihsg kalau 1 mesin (lebih hemat). Kosong =
# fallback ke Redis pub/sub channel IHSG_STREAM_CHANNEL (default 'ihsg:stream').
SHADOWSTREAM_WS_URL=
